# LLM Provider (OpenRouter recommended — model agnostic)
OPENROUTER_API_KEY=sk-or-xxx

# Telegram Bot
TELEGRAM_BOT_TOKEN=123456:ABC-xxx

# Gemini (for embeddings, TTS, memory loop)
GEMINI_API_KEY=xxx

# Optional: xAI (for image generation/vision)
XAI_API_KEY=xxx

# Optional: Perplexity (for web search)
PERPLEXITY_API_KEY=xxx

# Server
PORT=8080
LOG_LEVEL=info
